@media screen and (max-width: 1100px)
  .pasule-home-grid
    grid-template-columns: 1fr

  .pasule-card-grid,
  #recent-posts .recent-post-items
    grid-template-columns: 1fr

@media screen and (min-width: 901px)
  #rightside
    right: 18px
    bottom: var(--pasule-side-fab-offset)

@media screen and (max-width: 900px)
  #rightside
    right: 14px
    bottom: 92px

// Fix the Fomalhaut-inspired home layout so sections stay readable and inside the viewport.
.layout:has(> .pasule-home-shell)
