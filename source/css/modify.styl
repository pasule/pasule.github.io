
@import 'nib'

/** 页面头部 */
#page-header
  // 样式定义在下方
  background: transparent !important

  &:before
    background: transparent !important
    background: transparent !important

  &.post-bg, &.not-home-page
    height: 280px !important

  #post-info
    bottom: 40px !important

  #page-site-info
    top: 140px !important

  @media screen and (max-width: 768px)
    &.not-home-page
      height: 200px !important
    #post-info
      bottom: 10px !important
    #page-site-info
      top: 100px !important

.top-img
  height: 250px
  margin: -50px -40px 50px
  border-top-left-radius: inherit
  border-top-right-radius: inherit
  background-position: center center
  background-size: cover
  transition: all 0.3s

  @media screen and (max-width: 768px)
    height: 230px
    margin: -36px -14px 36px

  [data-theme='dark'] &
    filter: brightness(0.8)

// 页脚
#footer:before
  background-color: rgba(255, 255, 255, 0.5)

  [data-theme='dark'] &
    background-color: rgba(0, 0, 0, 0.5)

#footer-wrap, #footer-wrap a
  color: #111
  transition: unset

  [data-theme='dark'] &
    color: var(--light-grey)

:root
  --pasule-ink: #243047
  --pasule-muted: #617089
  --pasule-line: rgba(114, 128, 167, 0.16)
  --pasule-pink: #ff6fb1
  --pasule-blue: #6aa5ff
  --pasule-cream: rgba(255, 255, 255, 0.82)
  --pasule-shadow: 0 18px 40px rgba(112, 126, 161, 0.16)

#nav
  backdrop-filter: blur(12px)

#pasule-quick-jump .item-content,
#pasule-signal-note .item-content
  text-align: left

.pasule-link-stack
  display: grid
  gap: 10px

  a
    display: block
    padding: 10px 12px
    border-radius: 14px
    background: rgba(255, 255, 255, 0.72)
    border: 1px solid var(--pasule-line)
    color: var(--pasule-ink)
    transition: all .2s ease

    &:hover
      transform: translateY(-2px)
      box-shadow: var(--pasule-shadow)

.pasule-widget-copy
  margin: 0
  color: var(--pasule-muted)
  line-height: 1.7

.pasule-home-shell,
.pasule-project-page,
.pasule-about-page,
.pasule-post-guide
  color: var(--pasule-ink)

.pasule-home-shell
  display: grid
  gap: 20px
  margin-bottom: 24px

.pasule-home-hero,
.pasule-home-section,
.pasule-project-page,
.pasule-about-panel,
.pasule-post-guide
  border-radius: 24px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,255,255,.9))
  box-shadow: var(--pasule-shadow)

.pasule-home-hero
  padding: 28px
  background: linear-gradient(135deg, rgba(255,234,244,.96), rgba(230,242,255,.96))

.pasule-eyebrow,
.pasule-card-kicker
  margin: 0 0 8px
  font-size: .8rem
  letter-spacing: .08em
  text-transform: uppercase
  color: #6f5e8e

.pasule-hero-copy
  max-width: 48rem
  color: var(--pasule-muted)
  line-height: 1.8

.pasule-hero-actions
  display: flex
  flex-wrap: wrap
  gap: 12px
  margin-top: 18px

.pasule-primary-link,
.pasule-secondary-link,
.pasule-mini-link
  display: inline-flex
  align-items: center
  justify-content: center
  border-radius: 999px
  padding: 10px 16px

.pasule-primary-link
  color: #fff
  background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-blue))

.pasule-secondary-link,
.pasule-mini-link
  color: var(--pasule-ink)
  background: rgba(255,255,255,.76)
  border: 1px solid var(--pasule-line)

.pasule-home-grid,
.pasule-card-grid,
.pasule-about-grid
  display: grid
  gap: 16px

.pasule-card-grid
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr))

.pasule-home-section
  padding: 22px

.pasule-section-head
  display: flex
  align-items: center
  justify-content: space-between
  gap: 12px
  margin-bottom: 16px

  h2
    margin: 0

.pasule-feature-card,
.pasule-series-card,
.pasule-project-spotlight-card,
.pasule-project-card,
.pasule-about-panel
  padding: 18px
  border-radius: 18px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.72)

.pasule-mini-link-list,
.pasule-stack-list
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 12px

.pasule-post-guide
  margin-bottom: 24px
  padding: 18px 20px

.pasule-guide-links
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 14px

@media screen and (max-width: 768px)
  .pasule-home-hero,
  .pasule-home-section,
  .pasule-project-page,
  .pasule-about-panel,
  .pasule-post-guide
    border-radius: 18px

body
  --pasule-nav-pill-bg: rgba(255,255,255,.72)
  --pasule-nav-pill-border: rgba(114,128,167,.16)

#nav[data-pasule-nav-grouped]
  .menus_items
    display: flex
    align-items: center
    gap: 8px

  .menus_item > a.site-page
    padding: 8px 14px
    border-radius: 999px
    background: var(--pasule-nav-pill-bg)
    border: 1px solid var(--pasule-nav-pill-border)

.pasule-nav-group
  display: inline-flex
  align-items: center
  gap: 8px

body
  --pasule-nav-pill-bg: rgba(255,255,255,.72)
  --pasule-nav-pill-border: rgba(114,128,167,.16)

#nav[data-pasule-nav-grouped]
  .menus_items
    display: flex
    align-items: center
    gap: 8px

  .menus_item > a.site-page
    padding: 8px 14px
    border-radius: 999px
    background: var(--pasule-nav-pill-bg)
    border: 1px solid var(--pasule-nav-pill-border)

.pasule-nav-group
  display: inline-flex
  align-items: center
  gap: 8px

.pasule-home-carousel
  padding: 24px
  border-radius: 28px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(135deg, rgba(255,237,246,.94), rgba(230,242,255,.94))
  box-shadow: var(--pasule-shadow)

.pasule-swiper
  margin-top: 18px

.pasule-slide-card
  min-height: 260px
  padding: 26px
  border-radius: 24px
  background: rgba(255,255,255,.78)
  border: 1px solid var(--pasule-line)

.pasule-carousel-head
  max-width: 54rem

[data-pasule-feature-panels]
  display: grid
  gap: 18px

[data-pasule-announcement-panel]
  padding: 20px
  border-radius: 22px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.76)

[data-theme='dark']
  --pasule-ink: rgba(255,255,255,.88)
  --pasule-muted: rgba(220,228,245,.78)
  --pasule-line: rgba(145, 168, 255, 0.18)
  --pasule-shadow: 0 20px 42px rgba(0, 0, 0, 0.24)

  .pasule-home-carousel,
  .pasule-home-section,
  .pasule-project-page,
  .pasule-about-panel,
  .pasule-post-guide,
  #aside-content .card-widget
    background: linear-gradient(180deg, rgba(22,26,40,.76), rgba(14,18,30,.88))

  .pasule-slide-card,
  .pasule-feature-card,
  .pasule-series-card,
  .pasule-project-spotlight-card
    background: rgba(18,22,34,.74)

:root
  --pasule-home-max: 1280px
  --pasule-side-fab-offset: 170px

.pasule-home-shell
  max-width: var(--pasule-home-max)
  margin: 0 auto 24px

.pasule-home-carousel
  overflow: hidden

.pasule-swiper
  width: 100%
  overflow: hidden

  .swiper-wrapper
    align-items: stretch

  .swiper-slide
    width: 100% !important
    flex-shrink: 0
    box-sizing: border-box

.pasule-home-grid
  grid-template-columns: minmax(0, 1.35fr) minmax(320px, .72fr)
  align-items: start

.pasule-announcement-section
  min-height: 100%

.pasule-card-grid
  grid-template-columns: repeat(2, minmax(0, 1fr))

.pasule-slide-card
  min-height: 220px
  display: flex
  flex-direction: column
  justify-content: space-between

.pasule-feature-card,
.pasule-series-card,
.pasule-project-spotlight-card
  min-height: 180px

#recent-posts .recent-post-items
  display: grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 18px

  .recent-post-item
    width: 100%
    margin: 0

@media screen and (max-width: 1100px)
  .pasule-home-grid
    grid-template-columns: 1fr

  .pasule-card-grid,
  #recent-posts .recent-post-items
    grid-template-columns: 1fr

@media screen and (min-width: 901px)
  #rightside
    right: 18px
    bottom: var(--pasule-side-fab-offset)

@media screen and (max-width: 900px)
  #rightside
    right: 14px
    bottom: 92px

// Fix the Fomalhaut-inspired home layout so sections stay readable and inside the viewport.
.pasule-home-shell
  gap: 16px

.pasule-home-carousel
  min-height: 0
  overflow: hidden !important

.pasule-swiper
  position: relative
  width: 100%
  overflow: hidden !important
  min-height: 260px

  .swiper-wrapper
    position: relative
    min-height: inherit

  .swiper-slide
    display: none
    width: 100%
    min-height: 260px
    flex-direction: column
    justify-content: space-between

    &.is-active
      display: flex

.swiper-pagination
  display: flex
  align-items: center
  gap: 8px
  margin-top: 16px

.pasule-swiper-dot
  width: 10px
  height: 10px
  border: 0
  border-radius: 999px
  background: rgba(111, 94, 142, 0.24)
  cursor: pointer
  transition: all .2s ease

  &.is-active
    width: 28px
    background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-blue))

.pasule-home-grid
  grid-template-columns: 1fr !important
  gap: 16px

.pasule-home-section
  padding: 18px

.pasule-card-grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 14px

.pasule-announcement-section
  min-height: auto

.pasule-feature-card,
.pasule-series-card,
.pasule-project-spotlight-card
  min-height: 0

  h3
    margin-bottom: 10px
    line-height: 1.45
    font-size: 1.35rem

  p
    line-height: 1.85

#recent-posts .recent-post-items
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important
  gap: 16px

#recent-posts .recent-post-item
  min-height: 0

  .article-title
    font-size: 1.2rem

  .content
    -webkit-line-clamp: 4

@media screen and (min-width: 901px)
  #rightside
    right: 16px !important
    bottom: 220px !important

@media screen and (max-width: 1200px)
  .pasule-card-grid,
  #recent-posts .recent-post-items
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important

@media screen and (max-width: 900px)
  .pasule-card-grid,
  #recent-posts .recent-post-items
    grid-template-columns: 1fr !important

  .pasule-swiper
    min-height: 220px

    .swiper-slide
      min-height: 220px

// Pasule home densify fixes v2
.pasule-topic-atlas
  display: grid
  grid-template-columns: repeat(4, minmax(0, 1fr))
  gap: 14px

.pasule-topic-card
  display: flex
  flex-direction: column
  gap: 10px
  min-height: 100%
  padding: 18px 18px 20px
  border-radius: 20px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,255,255,.92))
  box-shadow: var(--pasule-shadow)
  color: var(--pasule-ink)
  text-decoration: none
  transition: transform .22s ease, box-shadow .22s ease

  &:hover
    transform: translateY(-4px)
    box-shadow: 0 22px 44px rgba(111, 126, 160, 0.18)

  h3
    margin: 0
    line-height: 1.35

  p
    margin: 0
    color: var(--pasule-muted)
    line-height: 1.75

.pasule-topic-link
  margin-top: auto
  color: #6f5e8e
  font-weight: 700

#aside-content .card-tag-cloud
  display: flex
  flex-wrap: wrap
  gap: 10px
  line-height: 1.8

  a
    display: inline-flex
    align-items: center
    justify-content: center
    margin: 0 !important
    padding: 7px 12px
    border-radius: 999px
    background: rgba(255,255,255,.8)
    border: 1px solid var(--pasule-line)
    color: var(--pasule-ink) !important
    transition: transform .18s ease, box-shadow .18s ease

    &:hover
      transform: translateY(-2px)
      box-shadow: var(--pasule-shadow)

#recent-posts
  margin-top: 8px

#recent-posts .recent-post-items
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important
  gap: 18px !important

#recent-posts .recent-post-item
  display: grid !important
  grid-template-rows: auto 1fr
  align-items: stretch
  min-height: 100%
  border-radius: 22px

#recent-posts .post_cover
  float: none !important
  width: 100% !important
  margin: 0 !important

  a
    display: block
    aspect-ratio: 16 / 9

  img
    width: 100%
    height: 100%
    object-fit: cover

#recent-posts .recent-post-info
  display: flex
  flex-direction: column
  gap: 12px
  min-width: 0
  padding: 18px 20px 20px

#recent-posts .article-meta-wrap
  display: flex
  flex-wrap: wrap
  gap: 8px 10px

#recent-posts .article-title
  display: -webkit-box
  overflow: hidden
  -webkit-box-orient: vertical
  -webkit-line-clamp: 2

#recent-posts .content
  display: -webkit-box
  overflow: hidden
  margin: 0
  line-height: 1.8
  -webkit-box-orient: vertical
  -webkit-line-clamp: 5

@media screen and (min-width: 901px)
  #rightside
    right: 16px !important
    bottom: 248px !important

@media screen and (max-width: 1280px)
  .pasule-topic-atlas
    grid-template-columns: repeat(2, minmax(0, 1fr))

@media screen and (max-width: 1100px)
  #recent-posts .recent-post-items
    grid-template-columns: 1fr !important

@media screen and (max-width: 768px)
  .pasule-topic-atlas
    grid-template-columns: 1fr

  #aside-content .card-tag-cloud
    gap: 8px

    a
      padding: 6px 10px

// Article page second cycle: info cards, reading rail and stronger closure.
#post #article-container
  display: grid
  gap: 18px

.pasule-article-brief
  display: grid
  gap: 18px
  margin-bottom: 4px
  padding: 24px
  border-radius: 24px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(180deg, rgba(255,255,255,.84), rgba(255,255,255,.94))
  box-shadow: var(--pasule-shadow)

.pasule-article-brief-main
  display: grid
  gap: 12px

  h2
    margin: 0
    line-height: 1.3

.pasule-article-meta-grid
  display: grid
  grid-template-columns: repeat(4, minmax(0, 1fr))
  gap: 14px

.pasule-brief-stat
  padding: 16px 18px
  border-radius: 18px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.78)

  h3
    margin: 6px 0 8px
    font-size: 1.35rem
    line-height: 1.2

  p:last-child
    margin: 0
    color: var(--pasule-muted)
    line-height: 1.7

.pasule-inline-progress,
.pasule-reading-progress
  display: grid
  gap: 10px

.pasule-progress-meta
  display: flex
  align-items: center
  justify-content: space-between
  gap: 12px

  span
    color: var(--pasule-muted)

  strong
    font-size: 1.2rem
    color: var(--pasule-ink)

.pasule-progress-track
  width: 100%
  height: 10px
  overflow: hidden
  border-radius: 999px
  background: rgba(111, 94, 142, 0.12)

  span
    display: block
    width: 0
    height: 100%
    border-radius: inherit
    background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-blue))
    transition: width .2s ease

.pasule-post-guide
  padding: 22px

.pasule-post-guide-grid
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  gap: 14px

.pasule-guide-panel
  padding: 18px
  border-radius: 20px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.74)

  h3
    margin: 4px 0 10px
    line-height: 1.35

  p
    margin: 0
    line-height: 1.8
    color: var(--pasule-muted)

.pasule-guide-list
  margin: 0
  padding: 0
  list-style: none
  display: grid
  gap: 10px

  li
    position: relative
    padding-left: 16px
    color: var(--pasule-muted)
    line-height: 1.8

    &:before
      position: absolute
      top: .72rem
      left: 0
      width: 8px
      height: 8px
      border-radius: 999px
      background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-blue))
      content: ''

.pasule-reading-rail
  border-radius: 24px !important
  border: 1px solid var(--pasule-line) !important
  overflow: hidden

.pasule-current-section
  margin: 0
  color: var(--pasule-muted)
  line-height: 1.7

.pasule-reading-rail-grid
  display: grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 12px
  margin-top: 14px

.pasule-rail-stat
  padding: 14px 16px
  border-radius: 16px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.7)
  display: grid
  gap: 6px

  span
    color: var(--pasule-muted)
    font-size: .92rem

  strong
    font-size: 1.1rem
    line-height: 1.2

.pasule-rail-block
  margin-top: 16px

.pasule-rail-links
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 8px

.pasule-rail-link
  display: inline-flex
  align-items: center
  justify-content: center
  padding: 9px 14px
  border-radius: 999px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.76)
  color: var(--pasule-ink)
  transition: transform .18s ease, box-shadow .18s ease

  &:hover
    transform: translateY(-2px)
    box-shadow: var(--pasule-shadow)

.pasule-article-outro
  margin-top: 10px
  padding: 22px
  border-radius: 24px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,255,255,.92))
  box-shadow: var(--pasule-shadow)

.post #aside-content .sticky_layout
  display: grid
  gap: 14px

.post #aside-content #card-toc,
.post #aside-content .card-post-series
  border-radius: 22px !important
  border: 1px solid var(--pasule-line)
  overflow: hidden

.post #aside-content #card-toc .toc-percentage
  display: none

.post #aside-content #card-toc .toc-content
  max-height: 360px
  overflow: auto
  padding-right: 4px

#page-header.post-bg
  #post-info #post-meta
    display: inline-grid
    gap: 8px
    padding: 12px 18px
    border-radius: 18px
    border: 1px solid rgba(255,255,255,.18)
    background: rgba(18, 22, 34, 0.26)
    backdrop-filter: blur(14px)

  #post-info .meta-firstline,
  #post-info .meta-secondline
    display: flex
    flex-wrap: wrap
    gap: 8px 10px
    justify-content: center

[data-theme='dark']
  .pasule-article-brief,
  .pasule-article-outro,
  .pasule-reading-rail,
  .pasule-guide-panel,
  .pasule-brief-stat
    background: linear-gradient(180deg, rgba(22,26,40,.76), rgba(14,18,30,.9))

  .pasule-rail-stat,
  .pasule-rail-link
    background: rgba(18,22,34,.74)

  #page-header.post-bg #post-info #post-meta
    background: rgba(9, 12, 22, 0.38)
    border-color: rgba(145, 168, 255, 0.14)

@media screen and (max-width: 1200px)
  .pasule-article-meta-grid
    grid-template-columns: repeat(2, minmax(0, 1fr))

  .pasule-post-guide-grid
    grid-template-columns: 1fr

@media screen and (max-width: 900px)
  .pasule-reading-rail-grid
    grid-template-columns: 1fr 1fr

@media screen and (max-width: 768px)
  .pasule-article-brief,
  .pasule-post-guide,
  .pasule-article-outro
    padding: 18px
    border-radius: 18px

  .pasule-article-meta-grid,
  .pasule-reading-rail-grid
    grid-template-columns: 1fr

  #page-header.post-bg #post-info #post-meta
    padding: 10px 14px
