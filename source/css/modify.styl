
@import 'nib'

/** 页面头部 */
#page-header
  // 样式定义在下方
  background: transparent !important

  &.full_page
    // Hero gradient overlay for better text readability
    &:before
      content: ''
      position: absolute
      inset: 0
      background: linear-gradient(180deg, rgba(16, 20, 36, 0.28) 0%, rgba(16, 20, 36, 0.12) 40%, rgba(16, 20, 36, 0.32) 100%)
      z-index: 0

    #site-info
      position: relative
      z-index: 1

    #site-title
      font-size: 2.8rem
      font-weight: 800
      letter-spacing: -.02em
      text-shadow: 0 2px 12px rgba(0,0,0,0.18)

    #site-subtitle
      font-size: 1.1rem
      opacity: .9

    #scroll-down
      z-index: 1

      .scroll-down-effects
        font-size: 1.5rem
        animation: pasuleScrollBounce 2s ease-in-out infinite

  @keyframes pasuleScrollBounce
    0%, 100%
      transform: translateY(0)
      opacity: .7
    50%
      transform: translateY(10px)
      opacity: 1

  &:not(.full_page):before
    background: transparent !important

  &.post-bg, &.not-home-page
    height: 280px !important

  #post-info
    bottom: 40px !important

  #page-site-info
    top: 140px !important

  @media screen and (max-width: 768px)
    &.not-home-page
      height: 200px !important
    #post-info
      bottom: 10px !important
    #page-site-info
      top: 100px !important

.top-img
  height: 250px
  margin: -50px -40px 50px
  border-top-left-radius: inherit
  border-top-right-radius: inherit
  background-position: center center
  background-size: cover
  transition: all 0.3s

  @media screen and (max-width: 768px)
    height: 230px
    margin: -36px -14px 36px

  [data-theme='dark'] &
    filter: brightness(0.8)

// 页脚
#footer:before
  background-color: rgba(255, 255, 255, 0.5)

  [data-theme='dark'] &
    background-color: rgba(0, 0, 0, 0.5)

#footer-wrap, #footer-wrap a
  color: #111
  transition: unset

  [data-theme='dark'] &
    color: var(--light-grey)

:root
  --pasule-ink: #1a2332
  --pasule-muted: #5b6e8c
  --pasule-line: rgba(114, 128, 167, 0.14)
  --pasule-pink: #f8588c
  --pasule-blue: #5b8def
  --pasule-purple: #7c5ce7
  --pasule-cream: rgba(255, 255, 255, 0.84)
  --pasule-shadow: 0 8px 32px rgba(92, 101, 138, 0.12)
  --pasule-shadow-lg: 0 20px 48px rgba(92, 101, 138, 0.16)
  --pasule-glass-bg: rgba(255, 255, 255, 0.58)
  --pasule-glass-border: rgba(255, 255, 255, 0.64)
  --pasule-card-bg: rgba(255, 255, 255, 0.64)
  --pasule-gradient-warm: linear-gradient(135deg, rgba(255, 220, 235, 0.95), rgba(255, 240, 245, 0.92))
  --pasule-gradient-cool: linear-gradient(135deg, rgba(225, 238, 255, 0.95), rgba(240, 245, 255, 0.92))
  --pasule-radius-sm: 16px
  --pasule-radius: 22px
  --pasule-radius-lg: 28px

#nav
  backdrop-filter: blur(12px)

/* 全局容器更明亮 */
.content-wrap
  background: rgba(255,255,255,0.72) !important
  backdrop-filter: blur(20px) saturate(120%) !important
  -webkit-backdrop-filter: blur(20px) saturate(120%) !important
  box-shadow: 0 8px 32px rgba(92, 101, 138, 0.08) !important
  border-radius: 24px !important
  border: 1px solid rgba(255,255,255,0.6) !important

/* 侧边栏卡片更明亮 */
#aside-content .card-widget
  background: rgba(255,255,255,0.78) !important
  backdrop-filter: blur(20px) saturate(120%) !important
  -webkit-backdrop-filter: blur(20px) saturate(120%) !important
  box-shadow: 0 8px 32px rgba(92, 101, 138, 0.1) !important
  border-radius: 18px !important
  border: 1px solid rgba(255,255,255,0.6) !important

/* 修复侧边栏卡片标题旋转问题 */
#aside-content .item-headline
  writing-mode: horizontal-tb !important
  transform: none !important
  padding: 13px 16px 9px !important
  border-bottom: 1px solid rgba(79, 125, 243, 0.13) !important
  margin: 0 16px 12px !important
  font-weight: 700 !important
  color: var(--pasule-purple, #7c5ce7) !important
  font-size: 0.9rem !important
  letter-spacing: 0 !important
  width: auto !important
  height: auto !important
  position: relative !important

/* 确保卡片标题图标正常显示 */
#aside-content .item-headline i
  width: auto !important
  height: auto !important
  line-height: 1 !important
  transform: none !important

/* 修复侧边栏文章列表项垂直旋转问题 */
#aside-content .aside-list,
#aside-content .aside-list-item
  writing-mode: horizontal-tb !important
  transform: none !important

#aside-content .aside-list-item .content
  writing-mode: horizontal-tb !important
  transform: none !important
  text-align: left !important

#aside-content .aside-list-item .name
  writing-mode: horizontal-tb !important
  transform: none !important
  text-align: left !important
  line-height: 1.5 !important
  font-weight: 500 !important

#aside-content .aside-list-item .datetime
  writing-mode: horizontal-tb !important
  transform: none !important
  text-align: left !important

#aside-content .card-archive-list-count,
#aside-content .card-archive-list-date
  writing-mode: horizontal-tb !important
  transform: none !important

.pasule-link-stack
  display: grid
  gap: 8px

  a
    display: flex
    align-items: center
    justify-content: center
    min-height: 38px
    padding: 8px 10px
    border-radius: 12px
    background: rgba(255,255,255,.56)
    backdrop-filter: blur(6px)
    -webkit-backdrop-filter: blur(6px)
    border: 1px solid var(--pasule-line)
    color: var(--pasule-ink)
    font-size: .88rem
    font-weight: 650
    transition: all .2s ease

    &:hover
      transform: translateY(-1px)
      color: var(--pasule-accent)
      box-shadow: var(--pasule-shadow)

.pasule-widget-copy
  margin: 0
  color: var(--pasule-muted)
  line-height: 1.7

.pasule-home-shell,
.pasule-project-page,
.pasule-about-page,
.pasule-post-guide
  color: var(--pasule-ink)

.pasule-home-shell
  display: grid
  gap: 20px
  margin-bottom: 24px

.pasule-home-hero,
.pasule-home-section,
.pasule-project-page,
.pasule-about-panel,
.pasule-post-guide
  border-radius: var(--pasule-radius-lg)
  border: 1px solid var(--pasule-line)
  background: var(--pasule-card-bg)
  backdrop-filter: blur(10px)
  -webkit-backdrop-filter: blur(10px)
  box-shadow: var(--pasule-shadow)

.pasule-home-hero
  padding: 28px
  background: var(--pasule-gradient-warm)

.pasule-eyebrow,
.pasule-card-kicker
  margin: 0 0 8px
  font-size: .75rem
  font-weight: 700
  letter-spacing: .1em
  text-transform: uppercase
  color: var(--pasule-purple)

.pasule-hero-copy
  max-width: 48rem
  color: var(--pasule-muted)
  line-height: 1.8

.pasule-hero-actions
  display: flex
  flex-wrap: wrap
  gap: 12px
  margin-top: 18px

.pasule-primary-link,
.pasule-secondary-link,
.pasule-mini-link
  display: inline-flex
  align-items: center
  justify-content: center
  border-radius: 999px
  padding: 10px 16px

.pasule-primary-link
  color: #fff
  background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-purple))
  padding: 10px 20px
  border-radius: 999px
  font-weight: 600
  transition: transform .2s ease, box-shadow .2s ease

  &:hover
    transform: translateY(-2px)
    box-shadow: 0 6px 20px rgba(120, 80, 200, 0.3)

.pasule-secondary-link,
.pasule-mini-link
  color: var(--pasule-ink)
  background: rgba(255,255,255,.76)
  border: 1px solid var(--pasule-line)

.pasule-home-grid,
.pasule-card-grid,
.pasule-about-grid
  display: grid
  gap: 16px

.pasule-card-grid
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr))

.pasule-home-section
  padding: 24px
  border-radius: var(--pasule-radius)
  border: 1px solid var(--pasule-line)
  background: var(--pasule-card-bg)
  backdrop-filter: blur(10px)
  -webkit-backdrop-filter: blur(10px)
  box-shadow: var(--pasule-shadow)

.pasule-section-head
  display: flex
  align-items: center
  justify-content: space-between
  gap: 12px
  margin-bottom: 20px
  padding-bottom: 14px
  border-bottom: 2px solid var(--pasule-line)

  h2
    margin: 0
    font-size: 1.35rem
    font-weight: 700
    letter-spacing: -.01em

  a
    font-size: .88rem
    color: var(--pasule-blue)
    font-weight: 600

.pasule-feature-card,
.pasule-series-card,
.pasule-project-spotlight-card,
.pasule-project-card,
.pasule-about-panel
  padding: 20px
  border-radius: var(--pasule-radius-sm)
  border: 1px solid var(--pasule-line)
  background: var(--pasule-glass-bg)
  backdrop-filter: blur(8px)
  -webkit-backdrop-filter: blur(8px)
  transition: transform .25s ease, box-shadow .25s ease

  &:hover
    transform: translateY(-3px)
    box-shadow: var(--pasule-shadow-lg)

.pasule-mini-link-list,
.pasule-stack-list
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 12px

.pasule-project-status
  display: inline-block
  margin-top: 8px
  padding: 4px 10px
  border-radius: 999px
  font-size: .78rem
  font-weight: 600
  background: rgba(124, 92, 231, 0.1)
  color: var(--pasule-purple)
  border: 1px solid rgba(124, 92, 231, 0.2)

.pasule-post-guide
  margin-bottom: 24px
  padding: 18px 20px

.pasule-guide-links
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 14px

@media screen and (max-width: 768px)
  .pasule-home-hero,
  .pasule-home-section,
  .pasule-project-page,
  .pasule-about-panel,
  .pasule-post-guide
    border-radius: 18px

body
  --pasule-nav-pill-bg: rgba(255,255,255,.58)
  --pasule-nav-pill-border: rgba(114,128,167,.12)

#nav[data-pasule-nav-grouped]
  height: 60px
  display: flex
  align-items: center

  #blog_name,
  #menus,
  #nav-right
    height: 100%
    display: flex
    align-items: center

  #blog_name
    min-width: 0

  #menus
    justify-content: flex-end
    gap: 10px

  #name-container
    display: none

  #toggle-menu
    display: none !important
    align-items: center
    justify-content: center
    width: 38px
    height: 38px
    margin: 0
    padding: 0
    border-radius: 999px
    color: var(--pasule-blue)
    line-height: 1

    a,
    .site-page
      display: inline-flex
      align-items: center
      justify-content: center
      width: 100%
      height: 100%

  .menus_items
    display: flex
    align-items: center
    height: 100%
    gap: 6px

  .menus_item
    position: relative
    display: flex
    align-items: center
    height: 100%
    padding: 0 !important
    overflow: visible

    &:hover,
    &:focus-within
      .menus_item_child
        opacity: 1
        visibility: visible
        pointer-events: auto
        transform: translate3d(-50%, 0, 0)

    .menus_item_child
      position: absolute !important
      top: calc(100% + 6px)
      left: 50%
      right: auto
      z-index: 120
      display: block !important
      margin-top: 0
      padding: 6px
      width: max-content
      min-width: 108px
      max-width: calc(100vw - 32px)
      overflow: visible
      border-radius: 10px
      background: rgba(255,255,255,.94)
      box-shadow: 0 12px 30px rgba(22, 39, 78, 0.18)
      opacity: 0
      visibility: hidden
      pointer-events: none
      animation: none
      transform: translate3d(-50%, 8px, 0)
      transition: opacity .18s ease, visibility .18s ease, transform .18s ease

      &:before
        top: -12px
        left: 0
        height: 14px

      li
        overflow: hidden
        border-radius: 7px

        &:hover
          background: rgba(91,141,239,.10)

        a
          display: flex
          align-items: center
          justify-content: center
          min-height: 40px
          padding: 0 14px
          white-space: nowrap
          color: var(--pasule-ink) !important

    &:nth-last-child(-n + 2)
      .menus_item_child
        left: auto
        right: 0
        transform: translate3d(0, 8px, 0)

    &:nth-last-child(-n + 2):hover,
    &:nth-last-child(-n + 2):focus-within
      .menus_item_child
        transform: translate3d(0, 0, 0)

  .menus_item > .site-page
    display: inline-flex !important
    align-items: center
    justify-content: center
    min-height: 36px
    padding: 0 14px
    border-radius: 999px
    background: var(--pasule-nav-pill-bg) !important
    backdrop-filter: blur(8px)
    -webkit-backdrop-filter: blur(8px)
    border: 1px solid var(--pasule-nav-pill-border) !important
    font-weight: 600
    font-size: .9rem
    line-height: 1
    text-shadow: none
    transition: background .2s ease, transform .2s ease

    &:hover
      transform: translateY(-1px)
      background: rgba(255,255,255,.78) !important

    &:after
      display: none

  @media screen and (max-width: 768px)
    #toggle-menu
      display: flex !important

    .menus_items
      display: none

.pasule-nav-group
  display: inline-flex
  align-items: center
  gap: 6px

.pasule-home-carousel
  padding: 24px
  border-radius: 22px
  border: 1px solid rgba(255,255,255,0.58)
  background: rgba(255,255,255,.68)
  box-shadow: 0 10px 28px rgba(55, 72, 120, 0.08)
  backdrop-filter: blur(18px) saturate(112%)
  -webkit-backdrop-filter: blur(18px) saturate(112%)

.pasule-swiper
  margin-top: 18px

.pasule-slide-card
  min-height: 210px
  padding: 22px
  border-radius: 18px
  background: rgba(255, 255, 255, 0.72)
  backdrop-filter: blur(12px) saturate(110%)
  -webkit-backdrop-filter: blur(12px) saturate(110%)
  border: 1px solid rgba(255, 255, 255, 0.58)
  box-shadow: none

.pasule-carousel-head
  max-width: 54rem

  h1
    font-size: 1.45rem
    font-weight: 800
    line-height: 1.3
    letter-spacing: -.01em
    margin: 8px 0 12px

[data-pasule-feature-panels]
  display: grid
  gap: 14px

[data-pasule-announcement-panel]
  padding: 20px
  border-radius: 20px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.58)
  box-shadow: 0 8px 22px rgba(55, 72, 120, 0.07)

[data-theme='dark']
  --pasule-ink: rgba(235, 240, 255, 0.92)
  --pasule-muted: rgba(200, 212, 245, 0.78)
  --pasule-line: rgba(150, 175, 255, 0.18)
  --pasule-shadow: 0 8px 32px rgba(0, 0, 0, 0.25)
  --pasule-shadow-lg: 0 20px 48px rgba(0, 0, 0, 0.32)
  --pasule-glass-bg: rgba(28, 32, 48, 0.72)
  --pasule-glass-border: rgba(255, 255, 255, 0.08)
  --pasule-card-bg: rgba(28, 32, 48, 0.78)
  --pasule-gradient-warm: linear-gradient(135deg, rgba(35, 30, 50, 0.95), rgba(25, 28, 45, 0.95))
  --pasule-gradient-cool: linear-gradient(135deg, rgba(28, 32, 52, 0.95), rgba(25, 30, 48, 0.95))

  .pasule-home-carousel,
  .pasule-home-section,
  .pasule-project-page,
  .pasule-about-panel,
  .pasule-post-guide,
  #aside-content .card-widget
    background: linear-gradient(180deg, rgba(35, 40, 60, 0.88), rgba(22, 26, 42, 0.92))
    border-color: rgba(150, 175, 255, 0.15)

  .pasule-slide-card,
  .pasule-feature-card,
  .pasule-series-card,
  .pasule-project-spotlight-card
    background: rgba(35, 40, 60, 0.82)
    border-color: rgba(150, 175, 255, 0.18)

  .pasule-primary-link
    box-shadow: 0 4px 16px rgba(120, 100, 240, 0.3)

  .pasule-section-head
    border-bottom-color: rgba(120, 150, 220, 0.12)

  .pasule-eyebrow,
  .pasule-card-kicker
    color: rgba(170, 190, 255, 0.85)

  /* 暗色模式侧边栏标题 */
  #aside-content .item-headline
    color: #a8b4ff !important
