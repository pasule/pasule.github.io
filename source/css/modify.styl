    padding: 6px 12px
    border-radius: 999px
    background: var(--pasule-glass-bg)
    backdrop-filter: blur(6px)
    -webkit-backdrop-filter: blur(6px)
    border: 1px solid var(--pasule-line)
    color: var(--pasule-ink) !important
    font-size: .86rem
    transition: transform .2s ease, box-shadow .2s ease, background .2s ease

    &:hover
      transform: translateY(-2px)
      box-shadow: var(--pasule-shadow)
      background: var(--pasule-cream)

#recent-posts
  margin-top: 8px

#recent-posts .recent-post-items
  grid-template-columns: repeat(2, minmax(0, 1fr)) !important
  gap: 18px !important

#recent-posts .recent-post-item
  display: grid !important
  grid-template-rows: auto 1fr
  align-items: stretch
  overflow: hidden
  min-height: 100%
  border-radius: var(--pasule-radius)
  border: 1px solid var(--pasule-line) !important
  background: var(--pasule-card-bg)
  backdrop-filter: blur(8px)
  -webkit-backdrop-filter: blur(8px)
  box-shadow: var(--pasule-shadow)
  transition: transform .25s ease, box-shadow .25s ease

  &:hover
    transform: translateY(-3px)
    box-shadow: var(--pasule-shadow-lg)

#recent-posts .post_cover
  float: none !important
  width: 100% !important
  margin: 0 !important

  a
    display: block
    aspect-ratio: 16 / 9

  img
    width: 100%
    height: 100%
    object-fit: cover

#recent-posts .recent-post-info
  position: relative
  display: flex
  flex-direction: column
  gap: 9px
  min-width: 0
  padding: 18px 20px 20px

#recent-posts .article-title
  display: -webkit-box
  overflow: hidden
  -webkit-box-orient: vertical
  -webkit-line-clamp: 2
  color: var(--pasule-heading)
  font-weight: 760
  line-height: 1.32

#recent-posts .article-meta-wrap
  color: var(--pasule-muted)
  font-size: .82rem
  line-height: 1.55

#recent-posts .article-meta-wrap i
  color: rgba(79, 125, 243, .72)

#recent-posts .content
  display: -webkit-box
  overflow: hidden
  margin: 0
  color: var(--pasule-body)
  font-size: .92rem
  line-height: 1.75
  -webkit-box-orient: vertical
  -webkit-line-clamp: 2

#recent-posts [data-pasule-post-card] .recent-post-info:after
  align-self: flex-start
  margin-top: auto
  padding-top: 2px
  color: var(--pasule-accent)
  font-size: .82rem
  font-weight: 700
  content: '阅读全文 →'

#aside-content .card-info
  padding: 20px 18px 18px !important

  .avatar-img
    width: 78px !important
    height: 78px !important
    margin: 0 auto 10px !important
    border-radius: 50% !important
    box-shadow: 0 8px 20px rgba(36,48,72,.12)

  .author-info-name
    margin-bottom: 4px
    color: var(--pasule-heading)
    font-size: 1.08rem
    font-weight: 760
    line-height: 1.25

  .author-info-description
    max-width: 210px
    margin: 0 auto 14px
    color: var(--pasule-body)
    font-size: .84rem
    line-height: 1.65

  .site-data
    display: grid
    grid-template-columns: repeat(3, minmax(0, 1fr))
    gap: 8px
    margin: 0 0 12px !important

    a
      padding: 8px 4px
      border-radius: 12px
      background: rgba(255,255,255,.5)
      border: 1px solid var(--pasule-border)

    .headline
      color: var(--pasule-muted)
      font-size: .74rem

    .length-num
      color: var(--pasule-heading)
      font-size: 1rem
      font-weight: 760

  #card-info-btn
    min-height: 36px
    margin: 0 0 12px !important
    border-radius: 12px !important
    background: rgba(79,125,243,.12) !important
    color: var(--pasule-accent) !important
    box-shadow: none !important
    font-size: .88rem

  .card-info-social-icons
    margin: 0 !important
    gap: 16px
    font-size: 1.05rem

#aside-content .card-announcement,
#aside-content #pasule-station-note
  .announcement_content,
  .pasule-widget-copy
    padding: 0 18px 18px
    color: var(--pasule-body)
    font-size: .86rem
    line-height: 1.75

#aside-content #pasule-quick-jump .pasule-link-stack
  grid-template-columns: repeat(2, minmax(0, 1fr))
  padding: 0 16px 16px

#aside-content #pasule-quick-jump .item-content
  padding: 0 !important

@media screen and (min-width: 901px)
  #rightside
    right: 16px !important
    bottom: 248px !important

@media screen and (max-width: 1100px)
  #recent-posts .recent-post-items
    grid-template-columns: 1fr !important

@media screen and (max-width: 768px)
  #aside-content .card-tag-cloud
    gap: 8px

    a
      padding: 6px 10px

// Article page second cycle: info cards, reading rail and stronger closure.
#post #article-container
  display: grid
  gap: 18px

.pasule-article-brief
  display: grid
  gap: 18px
  margin-bottom: 4px
  padding: 24px
  border-radius: 24px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(180deg, rgba(255,255,255,.84), rgba(255,255,255,.94))
  box-shadow: var(--pasule-shadow)

.pasule-article-brief-main
  display: grid
  gap: 12px

  h2
    margin: 0
    line-height: 1.3

.pasule-article-meta-grid
  display: grid
  grid-template-columns: repeat(4, minmax(0, 1fr))
  gap: 14px

.pasule-brief-stat
  padding: 16px 18px
  border-radius: 18px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.78)

  h3
    margin: 6px 0 8px
    font-size: 1.35rem
    line-height: 1.2

  p:last-child
    margin: 0
    color: var(--pasule-muted)
    line-height: 1.7

.pasule-inline-progress,
.pasule-reading-progress
  display: grid
  gap: 10px

.pasule-progress-meta
  display: flex
  align-items: center
  justify-content: space-between
  gap: 12px

  span
    color: var(--pasule-muted)

  strong
    font-size: 1.2rem
    color: var(--pasule-ink)

.pasule-progress-track
  width: 100%
  height: 10px
  overflow: hidden
  border-radius: 999px
  background: rgba(111, 94, 142, 0.12)

  span
    display: block
    width: 0
    height: 100%
    border-radius: inherit
    background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-purple))
    transition: width .2s ease

.pasule-post-guide
  padding: 22px

.pasule-post-guide-grid
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  gap: 14px

.pasule-guide-panel
  padding: 18px
  border-radius: 20px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.74)

  h3
    margin: 4px 0 10px
    line-height: 1.35

  p
    margin: 0
    line-height: 1.8
    color: var(--pasule-muted)

.pasule-guide-list
  margin: 0
  padding: 0
  list-style: none
  display: grid
  gap: 10px

  li
    position: relative
    padding-left: 16px
    color: var(--pasule-muted)
    line-height: 1.8

    &:before
      position: absolute
      top: .72rem
      left: 0
      width: 8px
      height: 8px
      border-radius: 999px
      background: linear-gradient(135deg, var(--pasule-pink), var(--pasule-purple))
      content: ''

.pasule-reading-rail
  border-radius: 24px !important
  border: 1px solid var(--pasule-line) !important
  overflow: hidden

.pasule-current-section
  margin: 0
  color: var(--pasule-muted)
  line-height: 1.7

.pasule-reading-rail-grid
  display: grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 12px
  margin-top: 14px

.pasule-rail-stat
  padding: 14px 16px
  border-radius: 16px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.7)
  display: grid
  gap: 6px

  span
    color: var(--pasule-muted)
    font-size: .92rem

  strong
    font-size: 1.1rem
    line-height: 1.2

.pasule-rail-block
  margin-top: 16px

.pasule-rail-links
  display: flex
  flex-wrap: wrap
  gap: 10px
  margin-top: 8px

.pasule-rail-link
  display: inline-flex
  align-items: center
  justify-content: center
  padding: 9px 14px
  border-radius: 999px
  border: 1px solid var(--pasule-line)
  background: rgba(255,255,255,.76)
  color: var(--pasule-ink)
  transition: transform .18s ease, box-shadow .18s ease

  &:hover
    transform: translateY(-2px)
    box-shadow: var(--pasule-shadow)

.pasule-article-outro
  margin-top: 10px
  padding: 22px
  border-radius: 24px
  border: 1px solid var(--pasule-line)
  background: linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,255,255,.92))
  box-shadow: var(--pasule-shadow)

.post #aside-content .sticky_layout
  display: grid
  gap: 14px

.post #aside-content #card-toc,
.post #aside-content .card-post-series
  border-radius: 22px !important
  border: 1px solid var(--pasule-line)
  overflow: hidden

.post #aside-content #card-toc .toc-percentage
  display: none

.post #aside-content #card-toc .toc-content
  max-height: 360px
  overflow: auto
  padding-right: 4px

#page-header.post-bg
  #post-info #post-meta
    display: inline-grid
    gap: 8px
    padding: 12px 18px
    border-radius: 18px
    border: 1px solid rgba(255,255,255,.18)
    background: rgba(18, 22, 34, 0.26)
    backdrop-filter: blur(14px)

  #post-info .meta-firstline,
  #post-info .meta-secondline
    display: flex
    flex-wrap: wrap
    gap: 8px 10px
    justify-content: center

[data-theme='dark']
  .pasule-article-brief,
  .pasule-article-outro,
  .pasule-reading-rail,
  .pasule-guide-panel,
  .pasule-brief-stat
    background: linear-gradient(180deg, rgba(22,26,40,.76), rgba(14,18,30,.9))

  .pasule-rail-stat,
  .pasule-rail-link
    background: rgba(18,22,34,.74)

  #page-header.post-bg #post-info #post-meta
    background: rgba(9, 12, 22, 0.38)
    border-color: rgba(145, 168, 255, 0.14)

@media screen and (max-width: 1200px)
  .pasule-article-meta-grid
    grid-template-columns: repeat(2, minmax(0, 1fr))

  .pasule-post-guide-grid
    grid-template-columns: 1fr

@media screen and (max-width: 900px)
  .pasule-reading-rail-grid
    grid-template-columns: 1fr 1fr

@media screen and (max-width: 768px)
  .pasule-article-brief,
  .pasule-post-guide,
  .pasule-article-outro
    padding: 18px
    border-radius: 18px

  .pasule-article-meta-grid,
  .pasule-reading-rail-grid
    grid-template-columns: 1fr

  #page-header.post-bg #post-info #post-meta
    padding: 10px 14px

// Pasule polish pass: clearer tokens, calmer reading surfaces, and active navigation.
:root
  --pasule-surface: rgba(255,255,255,.82)
  --pasule-surface-strong: rgba(255,255,255,.92)
  --pasule-surface-soft: rgba(248,250,255,.74)
  --pasule-border: rgba(92,108,145,.14)
  --pasule-accent: #4f7df3
  --pasule-accent-soft: rgba(79,125,243,.12)
  --pasule-accent-2: #ec5f93
  --pasule-heading: #142033
  --pasule-body: #2f405a
  --pasule-code-bg: rgba(18,24,38,.92)
  --pasule-focus-ring: rgba(79,125,243,.28)
  --pasule-radius-xs: 10px
  --pasule-radius-card: 18px
  --pasule-ease: cubic-bezier(.2,.8,.2,1)
  --pasule-shadow-soft: 0 10px 28px rgba(36,48,72,.08)
  --pasule-shadow-lift: 0 18px 38px rgba(36,48,72,.13)

.content-wrap,
#aside-content .card-widget,
.pasule-article-brief,
.pasule-post-guide,
.pasule-article-outro,
.pasule-reading-rail,
#recent-posts .recent-post-item
  background: var(--pasule-surface) !important
  border: 1px solid var(--pasule-border) !important
  box-shadow: var(--pasule-shadow-soft) !important
  backdrop-filter: blur(14px) saturate(112%) !important
  -webkit-backdrop-filter: blur(14px) saturate(112%) !important

.pasule-feature-card,
.pasule-series-card,
.pasule-project-spotlight-card,
.pasule-project-card,
.pasule-guide-panel,
.pasule-brief-stat,
.pasule-rail-stat
  background: var(--pasule-surface-soft) !important
  border: 1px solid var(--pasule-border) !important
  box-shadow: none

.pasule-feature-card:hover,
.pasule-series-card:hover,
.pasule-project-spotlight-card:hover,
.pasule-project-card:hover,
#recent-posts .recent-post-item:hover
  box-shadow: var(--pasule-shadow-lift) !important
  transform: translateY(-2px)

#nav[data-pasule-nav-grouped]
  .menus_item.is-current > .site-page,
  .menus_item > .site-page.is-active
    background: rgba(255,255,255,.9) !important
    border-color: rgba(79,125,243,.22) !important
    color: var(--pasule-accent) !important
    box-shadow: 0 8px 22px rgba(79,125,243,.14)

  .menus_item.is-current > .site-page:before
    position: absolute
    right: 12px
    bottom: 5px
    left: 12px
    height: 2px
    border-radius: 999px
    background: linear-gradient(90deg, var(--pasule-accent), var(--pasule-accent-2))
    content: ''

  .menus_item_child
    border: 1px solid var(--pasule-border)
    background: var(--pasule-surface-strong)
    backdrop-filter: blur(12px) saturate(112%)
    -webkit-backdrop-filter: blur(12px) saturate(112%)

    li a.is-active
      color: var(--pasule-accent) !important
      background: var(--pasule-accent-soft)
      font-weight: 700

  .menus_item > .site-page:focus-visible,
  .menus_item_child a:focus-visible
    outline: 3px solid var(--pasule-focus-ring)
    outline-offset: 3px

#post
  color: var(--pasule-body)

#post #article-container
  max-width: 76ch
  margin-inline: auto
  color: var(--pasule-body)
  font-size: 1.02rem
  line-height: 1.9

  > p,
  > ul,
  > ol
    margin: 0 0 1.05rem

  a:not(.pasule-mini-link):not(.pasule-rail-link)
    color: var(--pasule-accent)
    text-decoration: none
    background: linear-gradient(transparent 62%, rgba(79,125,243,.16) 0)

    &:hover
      color: #315fda
      background: linear-gradient(transparent 54%, rgba(79,125,243,.26) 0)

  h1,
  h2,
  h3,
  h4
    color: var(--pasule-heading)
    letter-spacing: 0
    line-height: 1.35
    scroll-margin-top: 86px

  h2
    margin-top: 2.2rem
    padding-bottom: .55rem
    border-bottom: 1px solid var(--pasule-border)
    font-size: 1.55rem

    &:before
      width: 8px
      height: 8px
      border-radius: 999px
      background: linear-gradient(135deg, var(--pasule-accent), var(--pasule-accent-2))

  h3
    margin-top: 1.7rem
    font-size: 1.22rem

  blockquote
    margin: 1.25rem 0
    padding: 16px 18px 16px 20px
    border-left: 4px solid var(--pasule-accent)
    border-radius: 0 var(--pasule-radius-xs) var(--pasule-radius-xs) 0
    background: rgba(79,125,243,.08)
    color: var(--pasule-body)

    p:last-child
      margin-bottom: 0

  .note
    border-radius: var(--pasule-radius-card)
    box-shadow: none

  code:not([class])
    padding: .16em .42em
    border-radius: 7px
    background: rgba(79,125,243,.10)
    color: #315fda
    font-size: .92em

  figure.highlight,
  pre
    border-radius: var(--pasule-radius-card) !important
    box-shadow: 0 12px 28px rgba(18,24,38,.18) !important

  figure.highlight
    overflow: hidden
    border: 1px solid rgba(255,255,255,.10)
    background: var(--pasule-code-bg) !important

  img
    border-radius: var(--pasule-radius-card)

.pasule-article-brief
  grid-template-columns: minmax(0, 1.08fr) minmax(260px, .92fr)
  align-items: start

  .pasule-article-meta-grid
    grid-template-columns: repeat(2, minmax(0, 1fr))

.pasule-article-brief-main h2
  color: var(--pasule-heading)
  font-size: 1.45rem

.pasule-guide-links,
.pasule-mini-link-list,
.pasule-rail-links
  gap: 8px

.pasule-mini-link,
.pasule-rail-link
  min-height: 34px
  border-radius: 999px
  border: 1px solid var(--pasule-border)
  background: rgba(255,255,255,.72)
  color: var(--pasule-body)
  font-weight: 650

  &:hover
    color: var(--pasule-accent)
    border-color: rgba(79,125,243,.24)
    background: rgba(255,255,255,.94)

.pasule-progress-track
  height: 8px
  background: rgba(79,125,243,.12)

  span
    background: linear-gradient(90deg, var(--pasule-accent), var(--pasule-accent-2))

.post #aside-content #card-toc .toc-content
  max-height: 420px

.post #aside-content #card-toc .toc-link
  border-radius: 8px
  padding: 5px 8px

  &.active
    background: var(--pasule-accent-soft)
    color: var(--pasule-accent)
    font-weight: 700

[data-theme='dark']
  --pasule-surface: rgba(24,28,42,.82)
  --pasule-surface-strong: rgba(28,33,49,.94)
  --pasule-surface-soft: rgba(35,40,58,.72)
  --pasule-border: rgba(155,176,235,.14)
  --pasule-accent: #8fb0ff
  --pasule-accent-soft: rgba(143,176,255,.14)
  --pasule-accent-2: #ff8db5
  --pasule-heading: rgba(245,248,255,.94)
  --pasule-body: rgba(225,232,248,.82)
  --pasule-code-bg: rgba(9,12,22,.94)
  --pasule-focus-ring: rgba(143,176,255,.3)

  #post #article-container
    color: var(--pasule-body)

    h1,
    h2,
    h3,
    h4
      color: var(--pasule-heading)

    blockquote
      background: rgba(143,176,255,.10)
      color: var(--pasule-body)

    code:not([class])
      background: rgba(143,176,255,.14)
      color: #bad0ff

  .pasule-mini-link,
  .pasule-rail-link
    background: rgba(35,40,58,.74)
    color: var(--pasule-body)

    &:hover
      background: rgba(42,49,70,.92)
      color: var(--pasule-accent)

  #nav[data-pasule-nav-grouped]
    .menus_item.is-current > .site-page,
    .menus_item > .site-page.is-active
      background: rgba(28,33,49,.92) !important
      color: var(--pasule-accent) !important

    .menus_item_child
      background: var(--pasule-surface-strong)

@media screen and (max-width: 900px)
  .pasule-article-brief
    grid-template-columns: 1fr

  #post #article-container
    max-width: 100%

@media screen and (max-width: 768px)
  #post #article-container
    font-size: 1rem
    line-height: 1.82

    h2
      font-size: 1.34rem

  .pasule-article-brief .pasule-article-meta-grid
    grid-template-columns: 1fr

body.pasule-home-page #rightside
  right: 18px !important
  bottom: 96px !important

body.pasule-home-page canvas[id^='live2d'],
body.pasule-home-page .live2d-widget-container
  transform: scale(.52)
  transform-origin: right bottom
