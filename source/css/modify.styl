  margin: 0 auto 24px

.pasule-home-carousel
  overflow: hidden

.pasule-swiper
  width: 100%
  overflow: hidden

  .swiper-wrapper
    align-items: stretch

  .swiper-slide
    width: 100% !important
    flex-shrink: 0
    box-sizing: border-box

.pasule-home-grid
  grid-template-columns: minmax(0, 1.35fr) minmax(320px, .72fr)
  align-items: start

.pasule-announcement-section
  min-height: 100%

.pasule-card-grid
  grid-template-columns: repeat(2, minmax(0, 1fr))

.pasule-slide-card
  min-height: 220px
